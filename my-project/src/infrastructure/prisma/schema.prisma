datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  @@map("usuarios")
}

model StagingPedido {
  id               Int      @id @default(autoincrement())
  orderId          String   @map("order_id")
  orderItemId      String   @map("order_item_id")
  purchaseDate     DateTime @map("purchase_date")
  paymentsDate     DateTime @map("payments_date")
  buyerEmail       String   @map("buyer_email")
  buyerName        String   @map("buyer_name")
  cpf              String
  buyerPhone       String   @map("buyer_phone")
  sku              String
  productName      String   @map("product_name")
  quantity         Int
  currency         String
  itemPrice        Decimal  @map("item_price") @db.Decimal(10, 2)
  shipServiceLevel String   @map("ship_service_level")
  shipAddress1     String   @map("ship_address1")
  shipCity         String   @map("ship_city")
  shipState        String   @map("ship_state")
  shipPostalCode   String   @map("ship_postal_code")
  shipCountry      String   @map("ship_country")

  @@map("staging_pedidos")
}

model Cliente {
  id       Int      @id @default(autoincrement())
  cpf      String   @unique
  nome     String
  email    String
  telefone String
  pedidos  Pedido[]

  @@map("clientes")
}

model Produto {
  id                   Int                   @id @default(autoincrement())
  sku                  String                @unique
  nome                 String
  preco                Decimal               @db.Decimal(10, 2)
  estoque              Estoque?
  itensPedido          ItemPedido[]
  movimentacoesEstoque MovimentacaoEstoque[]
  compras              Compra[]

  @@map("produtos")
}

model Estoque {
  produtoId  Int     @id @map("produto_id")
  quantidade Int
  produto    Produto @relation(fields: [produtoId], references: [id])

  @@map("estoque")
}

model Pedido {
  id                   Int                   @id @default(autoincrement())
  orderId              String                @map("order_id")
  clienteId            Int                   @map("cliente_id")
  data                 DateTime
  valorTotal           Decimal               @map("valor_total") @db.Decimal(10, 2)
  status               String                @default("Pendente")
  cliente              Cliente               @relation(fields: [clienteId], references: [id])
  itens                ItemPedido[]
  movimentacoesEstoque MovimentacaoEstoque[]

  @@map("pedidos")
}

model ItemPedido {
  id         Int     @id @default(autoincrement())
  pedidoId   Int     @map("pedido_id")
  produtoId  Int     @map("produto_id")
  quantidade Int
  precoUnit  Decimal @map("preco_unit") @db.Decimal(10, 2)
  pedido     Pedido  @relation(fields: [pedidoId], references: [id])
  produto    Produto @relation(fields: [produtoId], references: [id])

  @@map("itens_pedido")
}

model MovimentacaoEstoque {
  id         Int      @id @default(autoincrement())
  produtoId  Int      @map("produto_id")
  pedidoId   Int      @map("pedido_id")
  quantidade Int
  dataMov    DateTime @default(now()) @map("data_mov")
  produto    Produto  @relation(fields: [produtoId], references: [id])
  pedido     Pedido   @relation(fields: [pedidoId], references: [id])

  @@map("movimentacao_estoque")
}

model Compra {
  id         Int     @id @default(autoincrement())
  produtoId  Int     @map("produto_id")
  quantidade Int
  status     String  @default("Pendente")
  produto    Produto @relation(fields: [produtoId], references: [id])

  @@map("compras")
}
